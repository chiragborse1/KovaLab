{
  "name": "@kovaai/diagnostics-otel",
  "version": "2.0.0-beta.6",
  "description": "Kova diagnostics OpenTelemetry exporter",
  "type": "module",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@kovaai/diagnostics-otel",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.6"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.6"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
