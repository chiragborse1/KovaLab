{
  "name": "@kovaai/twitch",
  "version": "2.0.0-beta.6",
  "description": "Kova Twitch channel plugin",
  "type": "module",
  "dependencies": {
    "@twurple/api": "^8.1.3",
    "@twurple/auth": "^8.1.3",
    "@twurple/chat": "^8.1.3"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "install": {
      "minHostVersion": ">=2.0.0-beta.4"
    },
    "channel": {
      "id": "twitch",
      "label": "Twitch",
      "selectionLabel": "Twitch (Chat)",
      "docsPath": "/channels/twitch",
      "blurb": "Twitch chat integration",
      "aliases": [
        "twitch-chat"
      ]
    }
  }
}
