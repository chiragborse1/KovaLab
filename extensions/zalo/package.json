{
  "name": "@kovaai/zalo",
  "version": "2.0.0-beta.4",
  "description": "Kova Zalo channel plugin",
  "type": "module",
  "dependencies": {
    "undici": "7.25.0"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*",
    "getkova": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@kovaai/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.4"
    },
    "build": {
      "openclawVersion": "2.0.0-beta.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
