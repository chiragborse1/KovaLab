{
  "name": "@kovaai/voice-call",
  "version": "2.0.0-beta.5",
  "description": "Kova voice-call plugin",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.33",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*",
    "getkova": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@kovaai/voice-call",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.5"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.5"
    },
    "release": {
      "publishToKovaHub": true,
      "publishToNpm": true
    }
  }
}
