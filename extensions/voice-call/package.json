{
  "name": "@openclaw/voice-call",
  "version": "2.0.0",
  "description": "Kova voice-call plugin",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.33",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*",
    "openclaw": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2.0.0"
    },
    "compat": {
      "pluginApi": ">=2.0.0"
    },
    "build": {
      "openclawVersion": "2.0.0"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
