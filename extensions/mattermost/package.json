{
  "name": "@kovaai/mattermost",
  "version": "2.0.0-beta.6",
  "description": "Kova Mattermost channel plugin",
  "type": "module",
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*",
    "getkova": "workspace:*"
  },
  "peerDependencies": {
    "getkova": "^2.0.0-beta.6"
  },
  "peerDependenciesMeta": {
    "getkova": {
      "optional": true
    }
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "npmSpec": "@kovaai/mattermost",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.4"
    }
  }
}
