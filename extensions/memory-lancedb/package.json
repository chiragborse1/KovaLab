{
  "name": "@kovaai/memory-lancedb",
  "version": "2.0.0-beta.6",
  "description": "Kova LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "openai": "^6.34.0",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@kovaai/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.6"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.6"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
