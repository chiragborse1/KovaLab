{
  "name": "@openclaw/memory-lancedb",
  "version": "2.0.0",
  "description": "Kova LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "openai": "^6.34.0",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0"
    },
    "compat": {
      "pluginApi": ">=2.0.0"
    },
    "build": {
      "openclawVersion": "2.0.0"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
