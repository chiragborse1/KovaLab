{
  "name": "@kovaai/msteams",
  "version": "2.0.0-beta.6",
  "description": "Kova Microsoft Teams channel plugin",
  "type": "module",
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@microsoft/teams.api": "2.0.8",
    "@microsoft/teams.apps": "2.0.8",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "getkova": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60,
      "doctorCapabilities": {
        "dmAllowFromMode": "topOnly",
        "groupModel": "hybrid",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": true
      }
    },
    "install": {
      "npmSpec": "@kovaai/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.6"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.6"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToNpm": true
    }
  }
}
