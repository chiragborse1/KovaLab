{
  "name": "@kovaai/diffs",
  "version": "2.0.0-beta.6",
  "private": true,
  "description": "Kova diff viewer plugin",
  "type": "module",
  "scripts": {
    "build:viewer": "bun build src/viewer-client.ts --target browser --format esm --minify --outfile assets/viewer-runtime.js"
  },
  "dependencies": {
    "@pierre/diffs": "1.1.19",
    "@pierre/theme": "0.0.29",
    "playwright-core": "1.59.1",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*"
  },
  "kova": {
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "extensions": [
      "./index.ts"
    ]
  }
}
