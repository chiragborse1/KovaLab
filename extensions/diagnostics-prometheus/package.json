{
  "name": "@kovaai/diagnostics-prometheus",
  "version": "2.0.0-beta.5",
  "description": "Kova diagnostics Prometheus exporter",
  "type": "module",
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@kovaai/diagnostics-prometheus",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.5"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.5"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
