{
  "name": "@kovaai/nextcloud-talk",
  "version": "2.0.0-beta.6",
  "description": "Kova Nextcloud Talk channel plugin",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*",
    "getkova": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@kovaai/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.6"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.6"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
