{
  "name": "@kovaai/discord",
  "version": "2.0.0-beta.6",
  "description": "Kova Discord channel plugin",
  "type": "module",
  "dependencies": {
    "@buape/carbon": "0.16.0",
    "@discordjs/voice": "^0.19.2",
    "discord-api-types": "^0.38.47",
    "https-proxy-agent": "^9.0.0",
    "opusscript": "^0.1.1",
    "typebox": "1.1.38",
    "undici": "8.3.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*",
    "getkova": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "discord",
      "label": "Discord",
      "selectionLabel": "Discord (Bot API)",
      "detailLabel": "Discord Bot",
      "docsPath": "/channels/discord",
      "docsLabel": "discord",
      "blurb": "very well supported right now.",
      "systemImage": "bubble.left.and.bubble.right",
      "markdownCapable": true,
      "commands": {
        "nativeCommandsAutoEnabled": true,
        "nativeSkillsAutoEnabled": true
      },
      "configuredState": {
        "specifier": "./configured-state",
        "exportName": "hasDiscordConfiguredState"
      }
    },
    "install": {
      "npmSpec": "@kovaai/discord",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.6"
    },
    "build": {
      "kovaVersion": "2.0.0-beta.6"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToNpm": true
    }
  }
}
