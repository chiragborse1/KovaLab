{
  "name": "@kovaai/google-meet",
  "version": "2.0.0-beta.4",
  "description": "Kova Google Meet participant plugin",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*",
    "getkova": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@kovaai/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.3"
    },
    "compat": {
      "pluginApi": ">=2.0.0-beta.4"
    },
    "build": {
      "openclawVersion": "2.0.0-beta.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
