{
  "name": "@kovaai/synology-chat",
  "version": "2.0.0-beta.5",
  "description": "Synology Chat channel plugin for Kova",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@getkova/plugin-sdk": "workspace:*"
  },
  "kova": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to Kova with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@kovaai/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2.0.0-beta.4"
    }
  }
}
