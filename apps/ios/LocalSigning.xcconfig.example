// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

KOVA_CODE_SIGN_STYLE = Automatic
KOVA_DEVELOPMENT_TEAM = YOUR_TEAM_ID

KOVA_APP_BUNDLE_ID = ai.kova.client
KOVA_SHARE_BUNDLE_ID = ai.kova.client.share
KOVA_ACTIVITY_WIDGET_BUNDLE_ID = ai.kova.client.activitywidget
KOVA_WATCH_APP_BUNDLE_ID = ai.kova.client.watchkitapp
KOVA_WATCH_EXTENSION_BUNDLE_ID = ai.kova.client.watchkitapp.extension

// Leave empty with automatic signing.
KOVA_APP_PROFILE =
KOVA_SHARE_PROFILE =
KOVA_WATCH_APP_PROFILE =
KOVA_WATCH_EXTENSION_PROFILE =
